# Cloudflare Radar API (required for traffic data)
# Create token: dash.cloudflare.com → My Profile → API Tokens → "Cloudflare Radar: Read"
CLOUDFLARE_API_TOKEN=REDACTED

# MongoDB
MONGO_URI=mongodb://mongo:27017/cuba_monitor

# Google Cloud (optional — M-Lab BigQuery)
GOOGLE_APPLICATION_CREDENTIALS=/app/gcp-credentials.json
BIGQUERY_PROJECT=

# OpenAI (for AI-generated notes)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# Slack Bot (for sending notes to channel)
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# App
NODE_ENV=production
API_PORT=3000
ETL_PORT=4000
